# ============================================================
# CAB BOOKING APP — Root .env for Docker Compose
# Copy this file to .env and fill in real values
# ============================================================

# Database
DB_NAME=cabapp
DB_USER=cabuser
DB_PASSWORD=your_secure_db_password_here

# JWT — CHANGE THESE IN PRODUCTION (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters

# Stripe — Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=inr

# React App (Stripe public key)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# Email (Gmail: enable 2FA then generate App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=CabApp <no-reply@cabapp.com>

# URLs (update with your domain in production)
FRONTEND_URL=http://localhost
REACT_APP_API_URL=http://localhost/api
REACT_APP_SOCKET_URL=http://localhost

# Razorpay (https://dashboard.razorpay.com - free Indian payment gateway)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
