# =============================================
# CAB BOOKING APP - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cabapp
DB_USER=cabuser
DB_PASSWORD=cabpassword123

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_too
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe (Get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=inr

# Email (Use Gmail App Password or any SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=CabApp <no-reply@cabapp.com>

# Google Maps (Get from Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (Optional - for caching)
REDIS_URL=redis://redis:6379

# File Upload
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
